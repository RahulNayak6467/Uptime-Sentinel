{
  "name": "statusforge",
  "version": "0.1.0",
  "description": "API monitoring platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate": "node-pg-migrate up -m src/db/migrations",
    "migrate:down": "node-pg-migrate down -m src/db/migrations",
    "migrate:create": "node-pg-migrate create -m src/db/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.1",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "ioredis": "^5.11.0",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "resend": "^6.12.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "add": "^2.0.6",
    "jsonwebtoken": "^9.0.3",
    "pnpm": "^11.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
